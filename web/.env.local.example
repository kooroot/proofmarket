# ProofMarket frontend — copy to .env.local and fill real values (.env.local is gitignored).
# Public devnet values below are the pinned P1 deploy; the server-only secrets are placeholders.

# Devnet RPC (public endpoint; override with a private RPC if rate-limited).
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# ProofMarket's current deployed settlement program is devnet.
# Keep this as devnet unless you redeploy ProofMarket against TxLINE mainnet.
NEXT_PUBLIC_SETTLEMENT_TXLINE_NETWORK=devnet

# Deployed proofmarket program id (matches src/idl/proofmarket.json .address).
NEXT_PUBLIC_PROOFMARKET_PROGRAM_ID=6QNd5mHvV7czVkrRNdLPmuUybSwwdPWq9RYuwk5LZuEb

# Pinned legacy-SPL devnet test-USDC mint (6 decimals) from the P1 deploy.
NEXT_PUBLIC_USDC_MINT=2MYAvDHmZCnWUC4rMVYstLNniiXHuxo2Z7j7czaHA8LT

# --- server-only (never NEXT_PUBLIC_*); fill in .env.local, do not commit real values ---
# TxLINE data API network for /api/txline/* proxy routes: devnet or mainnet.
TXLINE_NETWORK=devnet
TXLINE_JWT=<server-only>
TXLINE_API_TOKEN=<server-only>
FAUCET_AUTHORITY_SECRET=<server-only base58 secret key of the USDC mint authority>
