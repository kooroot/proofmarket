# --- ProofMarket additions ---
# Node / package managers (Cargo.lock IS committed for reproducible SBF builds)
**/node_modules/
.pnp.*
# Bun is a supported first-class runner (bun install / bun run …); its lockfiles
# ARE committed for reproducible bun installs. Anchor.toml package_manager stays
# "yarn" only because anchor-cli 0.31 doesn't accept bun there (affects `anchor
# test` only, which this repo doesn't use — the Makefile drives builds).
# Next.js frontend (proofmarket/web)
web/.next/
web/out/
web/build/
web/next-env.d.ts
# Off-chain build output
offchain/dist/
offchain/cache/
**/*.tsbuildinfo
# Env files (permission-blocked; never commit secrets — templates are *.example)
.env
.env.*
!.env.example
!.env.local.example
# Logs / OS
*.log
# Program upgrade-authority keypair stays private (declared program id is public)
**/target/deploy/*-keypair.json
keys/
# TxODDS txoracle IDL is fetched, not shipped (offchain/src/ingestion/subscribe.ts):
#   anchor idl fetch 6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J --provider.cluster devnet -o offchain/src/idl/txoracle.json
offchain/src/idl/
